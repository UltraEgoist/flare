{
  "name": "vite-plugin-flare",
  "version": "0.1.0",
  "description": "Vite plugin for Flare (.flare) components - compile .flare files to Web Components",
  "main": "index.js",
  "module": "index.mjs",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./index.mjs",
      "require": "./index.js",
      "types": "./index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts"
  ],
  "keywords": [
    "vite",
    "plugin",
    "flare",
    "web-components",
    "compiler"
  ],
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "license": "MIT"
}
