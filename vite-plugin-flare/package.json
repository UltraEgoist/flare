{
  "name": "@aspect/vite-plugin-flare",
  "version": "0.1.0",
  "description": "Vite plugin for Flare (.flare) components — compile .flare files to Web Components with HMR support",
  "main": "index.js",
  "module": "index.mjs",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./index.mjs",
      "require": "./index.js",
      "types": "./index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts"
  ],
  "keywords": [
    "vite",
    "vite-plugin",
    "plugin",
    "flare",
    "web-components",
    "compiler",
    "hmr"
  ],
  "author": "Aspect",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aspect/flare.git",
    "directory": "vite-plugin-flare"
  },
  "homepage": "https://github.com/aspect/flare#readme",
  "bugs": {
    "url": "https://github.com/aspect/flare/issues"
  },
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "scripts": {
    "test": "node --test test/plugin.test.js"
  }
}
