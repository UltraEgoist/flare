<meta>
name: fl-alert
shadow: open
</meta>

<script>
prop variant: "info" | "success" | "warning" | "error" = "info"
prop dismissible: boolean = false
prop title: string = ""

state visible: boolean = true

emit dismiss: void

fn handleDismiss() {
  visible = false
  dismiss()
}
</script>

<template>
  <#if condition="visible">
    <div :class="['fl-alert', 'fl-alert--' + variant]" role="alert">
      <div class="fl-alert__content">
        <#if condition="title">
          <strong class="fl-alert__title">{{ title }}</strong>
        </#if>
        <div class="fl-alert__message"><slot></slot></div>
      </div>
      <#if condition="dismissible">
        <button class="fl-alert__dismiss" @click="handleDismiss" aria-label="Dismiss">&times;</button>
      </#if>
    </div>
  </#if>
</template>

<style>
:host { display: block; }
.fl-alert {
  display: flex; align-items: flex-start; gap: 0.75rem;
  padding: 0.875rem 1rem; border-radius: 8px; border-left: 4px solid; font-size: 0.875rem;
}
.fl-alert--info    { background: #eff6ff; border-color: #3b82f6; color: #1e40af; }
.fl-alert--success { background: #ecfdf5; border-color: #10b981; color: #065f46; }
.fl-alert--warning { background: #fffbeb; border-color: #f59e0b; color: #92400e; }
.fl-alert--error   { background: #fef2f2; border-color: #ef4444; color: #991b1b; }
.fl-alert__content { flex: 1; min-width: 0; }
.fl-alert__title { display: block; margin-bottom: 0.25rem; }
.fl-alert__message { line-height: 1.5; }
.fl-alert__dismiss {
  border: none; background: none; font-size: 1.25rem;
  color: inherit; opacity: 0.6; cursor: pointer; padding: 0; line-height: 1;
}
.fl-alert__dismiss:hover { opacity: 1; }
</style>
