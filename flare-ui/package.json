{
  "name": "@aspect/flare-ui",
  "version": "0.1.0",
  "description": "Official UI component library for Flare — pre-built, accessible Web Components",
  "main": "dist/flare-ui.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/flare-ui.js",
      "types": "./index.d.ts"
    },
    "./components/*": "./dist/*.js"
  },
  "sideEffects": true,
  "files": [
    "dist/",
    "index.d.ts"
  ],
  "keywords": [
    "flare",
    "ui",
    "components",
    "web-components",
    "design-system",
    "accessible",
    "shadow-dom"
  ],
  "author": "Aspect",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aspect/flare.git",
    "directory": "flare-ui"
  },
  "homepage": "https://github.com/aspect/flare#readme",
  "bugs": {
    "url": "https://github.com/aspect/flare/issues"
  },
  "peerDependencies": {
    "@aspect/flare": ">=0.1.0"
  },
  "scripts": {
    "build": "node build.js",
    "test": "node --test test/components.test.js"
  }
}
