<meta>
name: todo-app
shadow: open
</meta>

<script>
state items: string[] = []
state newText: string = ""
state filter: string = "all"

computed activeCount: number = items.filter(i => !i.startsWith("[x] ")).length
computed completedCount: number = items.filter(i => i.startsWith("[x] ")).length

fn addItem() {
  if (newText.trim()) {
    items = [...items, newText.trim()]
    newText = ""
  }
}

fn toggleItem(index) {
  items = items.map((item, i) => {
    if (i === index) {
      return item.startsWith("[x] ") ? item.slice(4) : "[x] " + item
    }
    return item
  })
}

fn removeItem(index) {
  items = items.filter((_, i) => i !== index)
}

fn clearCompleted() {
  items = items.filter(i => !i.startsWith("[x] "))
}

fn setFilterAll() {
  filter = "all"
}

fn setFilterActive() {
  filter = "active"
}

fn setFilterDone() {
  filter = "done"
}

fn handleInput(e) {
  newText = e.target.value
}

fn handleKeydown(e) {
  if (e.key === "Enter") {
    addItem()
  }
}

computed filteredItems: string[] = items.filter(item => {
  if (filter === "active") return !item.startsWith("[x] ")
  if (filter === "done") return item.startsWith("[x] ")
  return true
})

on error {
  console.error("Todo app error:", error)
}
</script>

<template>
  <div class="todo-app">
    <h1 class="todo-app__title">Flare Todo</h1>

    <div class="todo-app__input-row">
      <input
        class="todo-app__input"
        :value="newText"
        placeholder="What needs to be done?"
        @input="handleInput"
        @keydown="handleKeydown"
      />
      <button class="todo-app__add-btn" @click="addItem">Add</button>
    </div>

    <div class="todo-app__filters">
      <button :class="['todo-app__filter', filter === 'all' ? 'todo-app__filter--active' : '']" @click="setFilterAll">All</button>
      <button :class="['todo-app__filter', filter === 'active' ? 'todo-app__filter--active' : '']" @click="setFilterActive">Active</button>
      <button :class="['todo-app__filter', filter === 'done' ? 'todo-app__filter--active' : '']" @click="setFilterDone">Done</button>
    </div>

    <ul class="todo-app__list">
      <#for each="item" of="filteredItems">
        <li :class="['todo-app__item', item.startsWith('[x] ') ? 'todo-app__item--done' : '']">
          <button class="todo-app__check" @click="toggleItem(index)">
            <#if condition="item.startsWith('[x] ')">✓<:else>○</#if>
          </button>
          <span class="todo-app__text">
            <#if condition="item.startsWith('[x] ')">{{ item.slice(4) }}<:else>{{ item }}</#if>
          </span>
          <button class="todo-app__remove" @click="removeItem(index)">×</button>
        </li>
      <:empty>
        <li class="todo-app__empty">
          <#if condition="filter === 'all'">No items yet. Add one above!
          <:else-if condition="filter === 'active'">No active items.
          <:else>No completed items.
          </#if>
        </li>
      </#for>
    </ul>

    <div class="todo-app__footer">
      <span>{{ activeCount }} item(s) left</span>
      <#if condition="completedCount > 0">
        <button class="todo-app__clear" @click="clearCompleted">Clear completed ({{ completedCount }})</button>
      </#if>
    </div>
  </div>
</template>

<style>
:host {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  max-width: 520px;
  margin: 0 auto;
  color: #1a1a2e;
}
.todo-app { background: #fff; border-radius: 12px; box-shadow: 0 4px 24px rgba(0,0,0,0.08); padding: 2rem; }
.todo-app__title { text-align: center; font-size: 2rem; font-weight: 700; margin: 0 0 1.5rem; color: #3b82f6; }
.todo-app__input-row { display: flex; gap: 0.5rem; margin-bottom: 1rem; }
.todo-app__input {
  flex: 1; padding: 0.75rem 1rem; border: 2px solid #e5e7eb; border-radius: 8px;
  font-size: 1rem; outline: none; transition: border-color 0.2s;
}
.todo-app__input:focus { border-color: #3b82f6; }
.todo-app__add-btn {
  padding: 0.75rem 1.25rem; background: #3b82f6; color: #fff; border: none;
  border-radius: 8px; font-size: 1rem; font-weight: 600; cursor: pointer;
  transition: background 0.15s;
}
.todo-app__add-btn:hover { background: #2563eb; }
.todo-app__filters { display: flex; gap: 0.5rem; margin-bottom: 1rem; }
.todo-app__filter {
  flex: 1; padding: 0.5rem; background: #f3f4f6; border: 2px solid transparent;
  border-radius: 6px; font-size: 0.875rem; cursor: pointer; text-align: center;
  transition: all 0.15s;
}
.todo-app__filter--active { border-color: #3b82f6; background: #eff6ff; color: #3b82f6; font-weight: 600; }
.todo-app__list { list-style: none; padding: 0; margin: 0; }
.todo-app__item {
  display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 0;
  border-bottom: 1px solid #f3f4f6;
}
.todo-app__item--done .todo-app__text { text-decoration: line-through; color: #9ca3af; }
.todo-app__check {
  width: 2rem; height: 2rem; border: 2px solid #d1d5db; border-radius: 50%;
  background: none; cursor: pointer; display: flex; align-items: center;
  justify-content: center; font-size: 0.875rem; transition: all 0.15s; flex-shrink: 0;
}
.todo-app__item--done .todo-app__check { border-color: #22c55e; color: #22c55e; background: #f0fdf4; }
.todo-app__text { flex: 1; font-size: 1rem; }
.todo-app__remove {
  width: 1.5rem; height: 1.5rem; border: none; background: none;
  color: #ef4444; cursor: pointer; font-size: 1.25rem; opacity: 0;
  transition: opacity 0.15s; flex-shrink: 0;
}
.todo-app__item:hover .todo-app__remove { opacity: 1; }
.todo-app__empty { padding: 2rem; text-align: center; color: #9ca3af; font-style: italic; }
.todo-app__footer {
  display: flex; justify-content: space-between; align-items: center;
  padding-top: 1rem; margin-top: 0.5rem; font-size: 0.875rem; color: #6b7280;
}
.todo-app__clear {
  background: none; border: none; color: #ef4444; cursor: pointer;
  font-size: 0.875rem; text-decoration: underline;
}
.todo-app__clear:hover { color: #dc2626; }
</style>
